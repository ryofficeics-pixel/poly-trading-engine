# ── Poly Trading Engine configuration ──────────────────────────────────────
# Copy to .env and adjust. All values have safe defaults.

# Account
DEFAULT_CAPITAL=1000.0

# Server
PORT=8000

# Per-trade position cap (hard limit, % of equity)
MAX_POSITION_PCT=10.0

# Heartbeat / persistence cadence
HEARTBEAT_INTERVAL=5
EQUITY_SNAPSHOT_EVERY=10

# ── Auto-trading strategy ───────────────────────────────────────────────────
SIGNAL_THRESHOLD=0.60        # long/short probability trigger
MAX_KELLY=0.20               # quarter-Kelly sizing cap
TAKE_PROFIT_PCT=1.5          # per-position take-profit %
STOP_LOSS_PCT=1.0            # per-position stop-loss %
MAX_HOLD_MINUTES=60          # force-exit after N minutes
MAX_OPEN_POSITIONS=3         # concurrent position slots
EXIT_CHECK_INTERVAL=2        # seconds between exit sweeps

# Database
DB_PATH=poly_engine.db
